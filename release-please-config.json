{
  "release-type": "node",
  "package-name": "transf-orm-cli",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features",
      "hidden": false
    },
    {
      "type": "fix",
      "section": "Bug Fixes",
      "hidden": false
    },
    {
      "type": "chore",
      "section": "Miscellaneous",
      "hidden": true
    }
  ],
  "extra-files": [
    {
      "type": "toml",
      "file": "Cargo.toml",
      "search": "version = \"(?<version>.*?)\"",
      "replaceGroup": "version"
    }
  ]
}
